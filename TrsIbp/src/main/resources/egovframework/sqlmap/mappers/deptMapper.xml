<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.co.TRSolution.trsIbp.dept.mapper.DeptMapper">

    <!-- ============================================================ -->
    <!--  DeptVO ResultMap                                             -->
    <!-- ============================================================ -->
    <resultMap id="deptResultMap" type="deptVO">
        <!-- DeptVO 직접 필드 -->
        <id     property="deptId"      column="DEPT_ID"/>
        <result property="deptNm"      column="DEPT_NM"/>
        <result property="upDeptId"    column="UP_DEPT_ID"/>
        <result property="sortDeptSeq" column="SORT_SEQ"/>
        <result property="upDeptNm"    column="UP_DEPT_NM"/>

        <!-- CompanyVO 상속 필드 -->
        <result property="coId"        column="CO_ID"/>

        <!-- CompanyVO 또는 BaseVO에 존재하는 경우 매핑됨 -->
        <result property="useYn"       column="USE_YN"/>
        <result property="regDt"       column="REG_DT"/>
    </resultMap>


    <!-- ============================================================ -->
    <!--  부서 목록 조회                                               -->
    <!-- ============================================================ -->
    <select id="selectDeptList" parameterType="userVO" resultMap="deptResultMap">
        SELECT
             D.DEPT_ID
            ,D.DEPT_NM
            ,D.UP_DEPT_ID
            ,D.CO_ID
            ,D.SORT_SEQ
            ,D.USE_YN
            ,D.REG_DT
            ,PD.DEPT_NM AS UP_DEPT_NM
        FROM dept_info D
        LEFT JOIN dept_info PD
               ON D.UP_DEPT_ID = PD.DEPT_ID
        WHERE D.USE_YN = 'Y'
        <if test="coId != null and coId != ''">
            AND D.CO_ID = #{coId}
        </if>
        ORDER BY D.SORT_SEQ ASC, D.DEPT_ID ASC
    </select>


    <!-- ============================================================ -->
    <!--  부서 등록                                                    -->
    <!-- ============================================================ -->
    <insert id="insertDept" parameterType="deptVO">
        INSERT INTO dept_info (
             DEPT_ID
            ,CO_ID
            ,DEPT_NM
            ,UP_DEPT_ID
            ,SORT_SEQ
            ,USE_YN
            ,REG_DT
        ) VALUES (
             #{deptId}
            ,#{coId}
            ,#{deptNm}
            ,<choose>
                <when test="upDeptId != null and upDeptId != ''">
                    #{upDeptId}
                </when>
                <otherwise>
                    NULL
                </otherwise>
             </choose>
            ,#{sortDeptSeq}
            ,'Y'
            ,NOW()
        )
    </insert>


    <!-- ============================================================ -->
    <!--  부서 트리 조회                                               -->
    <!--  jsTree 같은 화면용이면 Map 유지 가능                         -->
    <!-- ============================================================ -->
    <select id="selectDeptTreeList" parameterType="deptVO" resultType="java.util.LinkedHashMap">
        SELECT
             D.DEPT_ID AS id
            ,D.DEPT_NM AS text
            ,IFNULL(D.UP_DEPT_ID, '#') AS parent
            ,D.CO_ID AS coId
            ,D.SORT_SEQ AS sortDeptSeq
            ,D.USE_YN AS useYn
        FROM dept_info D
        WHERE D.CO_ID = #{coId}
          AND D.USE_YN = 'Y'
        ORDER BY D.UP_DEPT_ID ASC, D.SORT_SEQ ASC
    </select>


    <!-- ============================================================ -->
    <!--  부서 상세 조회                                               -->
    <!-- ============================================================ -->
    <select id="selectDeptDetail" parameterType="deptVO" resultMap="deptResultMap">
        SELECT
             D.DEPT_ID
            ,D.CO_ID
            ,D.DEPT_NM
            ,D.UP_DEPT_ID
            ,D.SORT_SEQ
            ,D.USE_YN
            ,D.REG_DT
            ,PD.DEPT_NM AS UP_DEPT_NM
        FROM dept_info D
        LEFT JOIN dept_info PD
               ON D.UP_DEPT_ID = PD.DEPT_ID
        WHERE D.DEPT_ID = #{deptId}
          AND D.CO_ID = #{coId}
    </select>


    <!-- ============================================================ -->
    <!--  부서 수정                                                    -->
    <!-- ============================================================ -->
    <update id="updateDept" parameterType="deptVO">
        UPDATE dept_info
        SET
             DEPT_NM = #{deptNm}
            ,SORT_SEQ = #{sortDeptSeq}
            <choose>
                <when test="upDeptId != null and upDeptId != ''">
                    ,UP_DEPT_ID = #{upDeptId}
                </when>
                <otherwise>
                    ,UP_DEPT_ID = NULL
                </otherwise>
            </choose>
        WHERE DEPT_ID = #{deptId}
          AND CO_ID = #{coId}
    </update>


    <!-- ============================================================ -->
    <!--  부서 삭제                                                    -->
    <!-- ============================================================ -->
    <update id="deleteDept" parameterType="deptVO">
        UPDATE dept_info
        SET USE_YN = 'N'
        WHERE DEPT_ID = #{deptId}
          AND CO_ID = #{coId}
    </update>

</mapper>