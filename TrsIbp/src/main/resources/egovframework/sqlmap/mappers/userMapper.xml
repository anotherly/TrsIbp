<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    사용자 SQL Mapper
    테이블: USER_INFO, AUTH_INFO, COMPANY_INFO, DEPT_INFO
    DB: MySQL/MariaDB
    작성일: 2026-05-28
-->
<mapper namespace="kr.co.TRSolution.trsIbp.user.mapper.UserMapper">

    <!-- ============================================================ -->
    <!--  ResultMap                                                    -->
    <!-- ============================================================ -->
    <resultMap type="userVO" id="userResultMap">
        <result property="userId"          column="USER_ID"         />
        <result property="userPw"          column="USER_PW"         />
        <result property="userName"        column="USER_NAME"       />
        <result property="companyId"       column="COMPANY_ID"      />
        <result property="companyName"     column="COMPANY_NAME"    />
        <result property="deptId"          column="DEPT_ID"         />
        <result property="deptName"        column="DEPT_NAME"       />
        <result property="parentDeptName"  column="PARENT_DEPT_NAME"/>
        <result property="position"        column="POSITION"        />
        <result property="authId"          column="AUTH_ID"         />
        <result property="authName"        column="AUTH_NAME"       />
        <result property="userTel"         column="USER_TEL"        />
        <result property="flagUse"         column="FLAG_USE"        />
        <result property="memo"            column="MEMO"            />
        <result property="regDt"           column="REG_DT"          />
    </resultMap>

    <!-- ============================================================ -->
    <!--  사용자 목록/단건 조회                                          -->
    <!--  USER_INFO + AUTH_INFO + COMPANY_INFO + DEPT_INFO JOIN        -->
    <!-- ============================================================ -->
    <select id="selectUser" parameterType="userVO" resultMap="userResultMap">
        SELECT
             U.USER_ID
            ,U.USER_NAME
            ,U.COMPANY_ID
            ,C.COMPANY_NAME
            ,U.DEPT_ID
            ,D.DEPT_NAME
            ,PD.DEPT_NAME    AS PARENT_DEPT_NAME
            ,U.POSITION
            ,U.AUTH_ID
            ,A.AUTH_NAME
            ,U.USER_TEL
            ,U.IN_TEL
            ,U.FLAG_USE
            ,U.MEMO
            ,DATE_FORMAT(U.REG_DT, '%Y-%m-%d') AS REG_DT
        FROM USER_INFO U
        LEFT JOIN AUTH_INFO    A  ON U.AUTH_ID    = A.AUTH_ID
        LEFT JOIN COMPANY_INFO C  ON U.COMPANY_ID = C.COMPANY_ID
        LEFT JOIN DEPT_INFO    D  ON U.DEPT_ID    = D.DEPT_ID
        LEFT JOIN DEPT_INFO    PD ON D.PARENT_DEPT_ID = PD.DEPT_ID
        WHERE 1=1
        <if test="userId    != null and userId    != ''">AND U.USER_ID    = #{userId}</if>
        <if test="userName  != null and userName  != ''">AND U.USER_NAME  LIKE CONCAT('%', #{userName}, '%')</if>
        <if test="companyId != null and companyId != ''">AND U.COMPANY_ID = #{companyId}</if>
        <if test="deptId    != null and deptId    != ''">AND U.DEPT_ID    = #{deptId}</if>
        <if test="authId    != null and authId    != ''">AND U.AUTH_ID    = #{authId}</if>
        <if test="flagUse   != null and flagUse   != ''">AND U.FLAG_USE   = #{flagUse}</if>
        <if test="searchValue != null and searchValue != ''">
            <choose>
                <when test="searchType == 'userId'">
                    AND U.USER_ID LIKE CONCAT('%', #{searchValue}, '%')
                </when>
                <otherwise>
                    AND U.USER_NAME LIKE CONCAT('%', #{searchValue}, '%')
                </otherwise>
            </choose>
        </if>
        <if test="sDate != null and sDate != '' and eDate != null and eDate != ''">
            AND U.REG_DT BETWEEN #{sDate} AND DATE_ADD(STR_TO_DATE(#{eDate}, '%Y-%m-%d'), INTERVAL 1 DAY)
        </if>
        ORDER BY U.REG_DT DESC
    </select>

    <!-- ============================================================ -->
    <!--  로그인용 단건 조회 (비밀번호 포함)                              -->
    <!-- ============================================================ -->
    <select id="selectUserForLogin" parameterType="userVO" resultMap="userResultMap">
        SELECT
             U.USER_ID
            ,U.USER_PW
            ,U.USER_NAME
            ,U.COMPANY_ID
            ,U.DEPT_ID
            ,U.POSITION
            ,U.AUTH_ID
            ,A.AUTH_NAME
            ,U.FLAG_USE
        FROM USER_INFO U
        LEFT JOIN AUTH_INFO A ON U.AUTH_ID = A.AUTH_ID
        WHERE U.USER_ID  = #{userId}
          AND U.FLAG_USE = 'Y'
    </select>

    <!-- ============================================================ -->
    <!--  사용자 등록                                                   -->
    <!-- ============================================================ -->
    <insert id="insertUser" parameterType="userVO">
        INSERT INTO USER_INFO (
             USER_ID
            ,USER_PW
            ,USER_NAME
            ,COMPANY_ID
            ,DEPT_ID
            ,POSITION
            ,AUTH_ID
            ,USER_TEL
            ,FLAG_USE
            ,MEMO
            ,REG_DT
        ) VALUES (
             #{userId}
            ,#{userPw}
            ,#{userName}
            ,#{companyId}
            ,#{deptId}
            ,#{position}
            ,#{authId}
            ,#{userTel}
            ,'Y'
            ,#{memo}
            ,NOW()
        )
    </insert>

    <!-- ============================================================ -->
    <!--  사용자 정보 수정                                              -->
    <!-- ============================================================ -->
    <update id="updateUser" parameterType="userVO">
        UPDATE USER_INFO
        SET
             USER_NAME  = #{userName}
            ,COMPANY_ID = #{companyId}
            ,DEPT_ID    = #{deptId}
            ,POSITION   = #{position}
            ,AUTH_ID    = #{authId}
            ,USER_TEL   = #{userTel}
            ,FLAG_USE   = #{flagUse}
            ,MEMO       = #{memo}
            <if test="userPw != null and userPw != ''">,USER_PW = #{userPw}</if>
        WHERE USER_ID = #{userId}
    </update>

    <!-- ============================================================ -->
    <!--  사용자 삭제                                                   -->
    <!-- ============================================================ -->
    <delete id="deleteUser" parameterType="userVO">
        DELETE FROM USER_INFO
        WHERE USER_ID = #{userId}
    </delete>


    <!-- ============================================================ -->
    <!--  회사 목록 조회                                                -->
    <!-- ============================================================ -->
    <select id="selectCompanyList" parameterType="userVO" resultType="java.util.LinkedHashMap">
        SELECT
             COMPANY_ID
            ,COMPANY_NAME
            ,COMPANY_TEL
            ,FLAG_USE
        FROM COMPANY_INFO
        WHERE FLAG_USE = 'Y'
        ORDER BY COMPANY_NAME ASC
    </select>

    <!-- ============================================================ -->
    <!--  권한 목록 조회                                                -->
    <!-- ============================================================ -->
    <select id="selectAuthList" resultType="java.util.LinkedHashMap">
        SELECT
             AUTH_ID
            ,AUTH_NAME
            ,AUTH_DESC
        FROM AUTH_INFO
        ORDER BY SORT_ORDER ASC
    </select>

</mapper>
