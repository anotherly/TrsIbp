<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    사용자 SQL Mapper
    테이블: USER_INFO, AUTHRT_INFO, CO_INFO, DEPT_INFO
    DB: MySQL/MariaDB
    작성일: 2026-05-28
-->
<mapper namespace="kr.co.TRSolution.trsIbp.user.mapper.UserMapper">

    <!-- ============================================================ -->
    <!--  ResultMap                                                    -->
    <!-- ============================================================ -->
    <resultMap type="userVO" id="userResultMap">
        <result property="userId"          column="USER_ID"         />
        <result property="userEnpswd"          column="USER_ENPSWD"         />
        <result property="userNm"        column="USER_NM"       />
        <result property="coId"       column="CO_ID"      />
        <result property="coNm"     column="CO_NM"    />
        <result property="deptId"          column="DEPT_ID"         />
        <result property="deptNm"        column="DEPT_NM"       />
        <result property="upDeptNm"  column="PARENT_DEPT_NM"/>
        <result property="jbpsNm"        column="JBPS_NM"        />
        <result property="authrtId"          column="AUTHRT_ID"         />
        <result property="authrtNm"        column="AUTHRT_NM"       />
        <result property="userTelno"         column="USER_TELNO"        />
        <result property="useYn"         column="USE_YN"        />
        <result property="memoCn"            column="MEMO_CN"            />
        <result property="regDt"           column="REG_DT"          />
    </resultMap>

    <!-- ============================================================ -->
    <!--  사용자 목록/단건 조회                                          -->
    <!--  USER_INFO + AUTHRT_INFO + CO_INFO + DEPT_INFO JOIN        -->
    <!-- ============================================================ -->
    <select id="selectUser" parameterType="userVO" resultMap="userResultMap">
        SELECT
             U.USER_ID
            ,U.USER_NM
            ,U.CO_ID
            ,C.CO_NM
            ,U.DEPT_ID
            ,D.DEPT_NM
            ,PD.DEPT_NM    AS PARENT_DEPT_NM
            ,U.JBPS_NM
            ,U.AUTHRT_ID
            ,A.AUTHRT_NM
            ,U.USER_TELNO
            ,U.EXT_NO
            ,U.USE_YN
            ,U.MEMO_CN
            ,DATE_FORMAT(U.REG_DT, '%Y-%m-%d') AS REG_DT
        FROM USER_INFO U
        LEFT JOIN AUTHRT_INFO    A  ON U.AUTHRT_ID    = A.AUTHRT_ID
        LEFT JOIN CO_INFO C  ON U.CO_ID = C.CO_ID
        LEFT JOIN DEPT_INFO    D  ON U.DEPT_ID    = D.DEPT_ID
        LEFT JOIN DEPT_INFO    PD ON D.UP_DEPT_ID = PD.DEPT_ID
        WHERE 1=1
        <if test="userId    != null and userId    != ''">AND U.USER_ID    = #{userId}</if>
        <if test="userNm  != null and userNm  != ''">AND U.USER_NM  LIKE CONCAT('%', #{userNm}, '%')</if>
        <if test="coId != null and coId != ''">AND U.CO_ID = #{coId}</if>
        <if test="deptId    != null and deptId    != ''">AND U.DEPT_ID    = #{deptId}</if>
        <if test="authrtId    != null and authrtId    != ''">AND U.AUTHRT_ID    = #{authrtId}</if>
        <if test="useYn   != null and useYn   != ''">AND U.USE_YN   = #{useYn}</if>
        <if test="searchValue != null and searchValue != ''">
            <choose>
                <when test="searchType == 'userId'">
                    AND U.USER_ID LIKE CONCAT('%', #{searchValue}, '%')
                </when>
                <otherwise>
                    AND U.USER_NM LIKE CONCAT('%', #{searchValue}, '%')
                </otherwise>
            </choose>
        </if>
        <if test="sDate != null and sDate != '' and eDate != null and eDate != ''">
            AND U.REG_DT BETWEEN #{sDate} AND DATE_ADD(STR_TO_DATE(#{eDate}, '%Y-%m-%d'), INTERVAL 1 DAY)
        </if>
        ORDER BY U.REG_DT DESC
    </select>

    <!-- ============================================================ -->
    <!--  로그인용 단건 조회 (비밀번호 포함)                              -->
    <!-- ============================================================ -->
    <select id="selectUserForLogin" parameterType="userVO" resultMap="userResultMap">
        SELECT
             U.USER_ID
            ,U.USER_ENPSWD
            ,U.USER_NM
            ,U.CO_ID
            ,U.DEPT_ID
            ,U.JBPS_NM
            ,U.AUTHRT_ID
            ,A.AUTHRT_NM
            ,U.USE_YN
        FROM USER_INFO U
        LEFT JOIN AUTHRT_INFO A ON U.AUTHRT_ID = A.AUTHRT_ID
        WHERE U.USER_ID  = #{userId}
          AND U.USE_YN = 'Y'
    </select>

    <!-- ============================================================ -->
    <!--  사용자 등록                                                   -->
    <!-- ============================================================ -->
    <insert id="insertUser" parameterType="userVO">
        INSERT INTO USER_INFO (
             USER_ID
            ,USER_ENPSWD
            ,USER_NM
            ,CO_ID
            ,DEPT_ID
            ,JBPS_NM
            ,AUTHRT_ID
            ,USER_TELNO
            ,USE_YN
            ,MEMO_CN
            ,REG_DT
        ) VALUES (
             #{userId}
            ,#{userEnpswd}
            ,#{userNm}
            ,#{coId}
            ,#{deptId}
            ,#{jbpsNm}
            ,#{authrtId}
            ,#{userTelno}
            ,'Y'
            ,#{memoCn}
            ,NOW()
        )
    </insert>

    <!-- ============================================================ -->
    <!--  사용자 정보 수정                                              -->
    <!-- ============================================================ -->
    <update id="updateUser" parameterType="userVO">
        UPDATE USER_INFO
        SET
             USER_NM  = #{userNm}
            ,CO_ID = #{coId}
            ,DEPT_ID    = #{deptId}
            ,JBPS_NM   = #{jbpsNm}
            ,AUTHRT_ID    = #{authrtId}
            ,USER_TELNO   = #{userTelno}
            ,USE_YN   = #{useYn}
            ,MEMO_CN       = #{memoCn}
            <if test="userEnpswd != null and userEnpswd != ''">,USER_ENPSWD = #{userEnpswd}</if>
        WHERE USER_ID = #{userId}
    </update>

    <!-- ============================================================ -->
    <!--  사용자 삭제                                                   -->
    <!-- ============================================================ -->
    <delete id="deleteUser" parameterType="userVO">
        DELETE FROM USER_INFO
        WHERE USER_ID = #{userId}
    </delete>


    <!-- ============================================================ -->
    <!--  회사 목록 조회                                                -->
    <!-- ============================================================ -->
    <select id="selectCompanyList" parameterType="userVO" resultType="java.util.LinkedHashMap">
        SELECT
             CO_ID
            ,CO_NM
            ,CO_TELNO
            ,USE_YN
        FROM CO_INFO
        WHERE USE_YN = 'Y'
        ORDER BY CO_NM ASC
    </select>

    <!-- ============================================================ -->
    <!--  권한 목록 조회                                                -->
    <!-- ============================================================ -->
    <select id="selectAuthList" resultType="java.util.LinkedHashMap">
        SELECT
             AUTHRT_ID
            ,AUTHRT_NM
            ,AUTHRT_EXPLN
        FROM AUTHRT_INFO
        ORDER BY SORT_SEQ ASC
    </select>

</mapper>
