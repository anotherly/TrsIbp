<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    근태관리 SQL Mapper
    테이블: WORK_HSTRY
    DB: MariaDB 10.6
    작성일: 2026-05-28
-->
<mapper namespace="kr.co.TRSolution.trsIbp.attend.mapper.AttendMapper">

    <!-- ============================================================ -->
    <!--  ResultMap                                                    -->
    <!-- ============================================================ -->
    <resultMap type="attendVO" id="attendResultMap">
        <result property="workHstrySn" column="WORK_HSTRY_SN"            />
        <result property="userId"       column="USER_ID"        />
        <result property="userNm"     column="USER_NM"      />
        <result property="workYmd"       column="WORK_YMD"        />
        <result property="gtwkDt"  column="GTWK_DT"  />
        <result property="lvwkDt" column="LVWK_DT" />
        <result property="powkNm" column="POWK_NM"  />
        <result property="workRmrkCn"     column="WORK_RMRK_CN"      />
        <result property="workMinutes"  column="WORK_MINUTES"   />
        <result property="regDt"        column="REG_DT"         />
        <result property="mdfcnDt"        column="MDFCN_DT"         />
    </resultMap>

    <!-- ============================================================ -->
    <!--  오늘 출퇴근 기록 조회                                          -->
    <!--  - userId + 오늘 날짜 기준                                     -->
    <!--  - 출근시간, 퇴근시간, 근무지, 근무분 반환                       -->
    <!-- ============================================================ -->
    <select id="selectTodayAttend" parameterType="attendVO" resultMap="attendResultMap">
        SELECT
            A.WORK_HSTRY_SN
            ,A.USER_ID
            ,A.WORK_YMD
            ,DATE_FORMAT(A.GTWK_DT,  '%H:%i') AS GTWK_DT
            ,DATE_FORMAT(A.LVWK_DT, '%H:%i') AS LVWK_DT
            ,A.POWK_NM
            ,A.WORK_RMRK_CN
            ,A.REG_DT
            ,A.MDFCN_DT
            /* 근무 분 계산: 퇴근기록 없으면 현재시각과 비교 */
            ,CASE
                WHEN A.LVWK_DT IS NOT NULL
                    THEN CAST(TIMESTAMPDIFF(MINUTE, A.GTWK_DT, A.LVWK_DT) AS CHAR)
                WHEN A.GTWK_DT IS NOT NULL
                    THEN CAST(TIMESTAMPDIFF(MINUTE, A.GTWK_DT, NOW()) AS CHAR)
                ELSE '0'
            END AS WORK_MINUTES
        FROM WORK_HSTRY A
        WHERE A.USER_ID = #{userId}
          AND A.WORK_YMD = CURDATE()
        LIMIT 1
    </select>

    <!-- ============================================================ -->
    <!--  출근 INSERT                                                  -->
    <!--  - WORK_YMD = 오늘, GTWK_DT = NOW()                     -->
    <!--  - UNIQUE KEY (USER_ID, WORK_YMD) → 하루 1회만 허용            -->
    <!-- ============================================================ -->
    <insert id="insertCheckIn" parameterType="attendVO">
        INSERT INTO WORK_HSTRY (
            USER_ID
            ,WORK_YMD
            ,GTWK_DT
            ,POWK_NM
            ,WORK_RMRK_CN
            ,REG_DT
        ) VALUES (
            #{userId}
            ,CURDATE()
            ,NOW()
            ,COALESCE(#{powkNm}, 'OFFICE')
            ,#{workRmrkCn}
            ,NOW()
        )
    </insert>

    <!-- ============================================================ -->
    <!--  퇴근 UPDATE                                                  -->
    <!--  - LVWK_DT = NOW(), MDFCN_DT = NOW()                    -->
    <!--  - 오늘 날짜 기준, FN_TIME이 없는 경우만 업데이트               -->
    <!-- ============================================================ -->
    <update id="updateCheckOut" parameterType="attendVO">
        UPDATE WORK_HSTRY
        SET
            LVWK_DT = NOW()
            ,MDFCN_DT        = NOW()
        WHERE USER_ID  = #{userId}
          AND WORK_YMD  = CURDATE()
          AND LVWK_DT IS NULL
    </update>

    <!-- ============================================================ -->
    <!--  근무지 변경 UPDATE                                            -->
    <!--  - 오늘 날짜 기준으로 근무지 업데이트                           -->
    <!--  - 출근 전이면 아무 일도 안 일어남 (레코드 없음)                 -->
    <!-- ============================================================ -->
    <update id="updatePowkNm" parameterType="attendVO">
        UPDATE WORK_HSTRY
        SET
            POWK_NM = #{powkNm}
            ,MDFCN_DT       = NOW()
        WHERE USER_ID = #{userId}
          AND WORK_YMD  = CURDATE()
    </update>

</mapper>
